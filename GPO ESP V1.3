        Title           = "Ui made by ok0f",
        Version         = "v1.1",
        Keybind         = "RightShift",
        ConfigFolder    = "Grand Piece Online",
        DefaultTab      = "Main",
        TabAlignment    = "Center",
        DefaultColor    = Color3.fromRGB(28, 27, 31),
        DefaultAccent   = Color3.fromRGB(208, 188, 255),
        DefaultSnowfall = true,
        DefaultScale    = 1.0,
        DefaultFont     = 5,
        ReloadCallback  = function() reload() end
    })

    local tabMain     = window:createtab("Main")
    local tabSettings = window:createtab("Settings")

    window:createlabel(tabMain, "Main", 1)
    window:createtoggle(tabMain, {
        Name = "Chest ESP", Col = 1, Default = cfg.enabled,
        HasKeybind = true, DefaultKeybind = "None",
        Callback = function(state) cfg.enabled = state end
    })

    window:createseparator(tabMain, 1)
    window:createlabel(tabMain, "Chest", 1)

    window:createtoggle(tabMain, {
        Name = "Mythical", Col = 1, Half = "Left", SameRow = true,
        Default = cfg.mythical,
        Callback = function(state) cfg.mythical = state end
    })
    window:createtoggle(tabMain, {
        Name = "Legendary", Col = 1, Half = "Right", SameRow = false,
        Default = cfg.legendary,
        Callback = function(state) cfg.legendary = state end
    })
    window:createtoggle(tabMain, {
        Name = "Rare", Col = 1, CustomWidth = 0.33, CustomOffset = 0, SameRow = true,
        Default = cfg.rare,
        Callback = function(state) cfg.rare = state end
    })
    window:createtoggle(tabMain, {
        Name = "Uncommon", Col = 1, CustomWidth = 0.33, CustomOffset = 0.33, SameRow = true,
        Default = cfg.uncommon,
        Callback = function(state) cfg.uncommon = state end
    })
    window:createtoggle(tabMain, {
        Name = "Common", Col = 1, CustomWidth = 0.33, CustomOffset = 0.66, SameRow = false,
        Default = cfg.common,
        Callback = function(state) cfg.common = state end
    })

    window:createseparator(tabMain, 1)
    window:createlabel(tabMain, "Vending Machines", 1)
    window:createtoggle(tabMain, {
        Name = "Vending ESP", Col = 1, Default = cfg.vending,
        Callback = function(state) cfg.vending = state end
    })

    window:settaborder({"Main", "Settings"})
end

reload()

-- ============================================================
-- HELPERS
-- ============================================================
local lp = game:GetService("Players").LocalPlayer

local function toV3(p)
    return Vector3.new(p.X, p.Y, p.Z)
end

local function getDist(a, b)
    local dx = a.X - b.X
    local dy = a.Y - b.Y
    local dz = a.Z - b.Z
    return math.sqrt(dx*dx + dy*dy + dz*dz)
end

-- ============================================================
-- CHEST DETECTION
-- ============================================================
local function getChestType(model)
    local hasBrown = false
    local hasGold  = false
    local hasBlue  = false
    local hasLeg   = false
    local hasMyth  = false

    for _, c in pairs(model:GetDescendants()) do
        if c.ClassName == "Weld" then
            local n = c.Name:lower()
            if string.find(n, "mythicalchest")  then hasMyth = true end
            if string.find(n, "legendarychest") then hasLeg  = true end
            if string.find(n, "blueche")        then hasBlue = true end
            if string.find(n, "chestyes_gold")  then hasGold = true end
            if string.find(n, "chestyes_brown") or string.find(n, "chestyes_grey") then hasBrown = true end
        end
    end

    if hasMyth                  then return "Mythical Chest"  end
    if hasLeg                   then return "Legendary Chest" end
    if hasBlue                  then return "Uncommon Chest"  end
    if hasGold and not hasBrown then return "Rare Chest"      end
    if hasBrown                 then return "Common Chest"    end
    return nil
end

local function isChest(model)
    if model.ClassName ~= "Model" then return false end
    local hasPrompt = false
    local hasWeld   = false
    for _, c in pairs(model:GetDescendants()) do
        if c.ClassName == "ProximityPrompt" then hasPrompt = true end
        if c.ClassName == "Weld" then
            local n = c.Name:lower()
            if string.find(n, "chestyes") or string.find(n, "blueche")
            or string.find(n, "legendarychest") or string.find(n, "mythicalchest") then
                hasWeld = true
            end
        end
        if hasPrompt and hasWeld then return true end
    end
    return false
end

local function getAnyPos(model)
    local ok1, pp = pcall(function() return model.PrimaryPart end)
    if ok1 and pp then
        local ok2, pos = pcall(function() return (pp :: any).Position end)
        if ok2 and pos then return toV3(pos) end
    end
    for _, c in pairs(model:GetDescendants()) do
        if c.ClassName == "MeshPart" or c.ClassName == "Part" then
            local ok, pos = pcall(function() return (c :: any).Position end)
            if ok and pos then return toV3(pos) end
        end
    end
    local ok3, cf = pcall(function() return model:GetPivot() end)
    if ok3 and cf then
        local p = cf.Position
        return Vector3.new(p.X, p.Y, p.Z)
    end
    return nil
end

local chestLabels = {}
local knownChests = {}

local function addChest(model)
    if knownChests[model] then return end
    if not isChest(model) then return end
    local ctype = getChestType(model)
    local pos   = getAnyPos(model)
    if not ctype or not pos then return end
    knownChests[model] = true
    local label = Drawing.new("Text")
    label.Size = 13 label.Center = true label.Outline = true label.Visible = false
    table.insert(chestLabels, {drawing = label, model = model, ctype = ctype, pos = pos})
end

-- Initial scan
local effects = workspace:FindFirstChild("Effects")
if effects then
    for _, m in pairs(effects:GetChildren()) do addChest(m) end
end

-- ============================================================
-- VENDING MACHINE DETECTION
-- ============================================================
local function getVendingLabel(model)
    local center = model:FindFirstChild("Center")
    if center then
        for _, c in pairs(center:GetChildren()) do
            local mapped = VENDING_SOUND_MAP[c.Name]
            if mapped then return mapped end
        end
    end
    return "Vending Machine"
end

local function getVendingPos(model)
    local center = model:FindFirstChild("Center")
    if center then
        local ok, pos = pcall(function() return (center :: any).Position end)
        if ok and pos then return toV3(pos) end
    end
    return getAnyPos(model)
end

local vendingLabels = {}
local knownVending  = {}

local function addVending(model)
    if knownVending[model] then return end
    if model.ClassName ~= "Model" then return end
    if model.Name ~= "VendingMachine" then return end
    local pos = getVendingPos(model)
    if not pos then return end
    knownVending[model] = true
    local lbl     = getVendingLabel(model)
    local drawing = Drawing.new("Text")
    drawing.Size = 13 drawing.Center = true drawing.Outline = true drawing.Visible = false
    table.insert(vendingLabels, {drawing = drawing, model = model, label = lbl, pos = pos})
end

-- Initial scan
local env = workspace:FindFirstChild("Env")
if env then
    for _, c in pairs(env:GetDescendants()) do addVending(c) end
end

-- ============================================================
-- MAIN LOOP
-- ============================================================
task.spawn(function()
    while true do
        task.wait(0.1)

        local cam = workspace.CurrentCamera
        if not cam then continue end

        local char   = lp.Character
        local hrp    = char and char:FindFirstChild("HumanoidRootPart")
        local hrpPos = nil
        if hrp then
            local ok, raw = pcall(function() return (hrp :: any).Position end)
            if ok and raw then hrpPos = toV3(raw) end
        end

        -- Rescan every tick — as fast as possible
        local efx = workspace:FindFirstChild("Effects")
        if efx then
            for _, m in pairs(efx:GetChildren()) do addChest(m) end
        end
        local ev = workspace:FindFirstChild("Env")
        if ev then
            for _, c in pairs(ev:GetDescendants()) do addVending(c) end
        end

        -- Chest ESP
        for _, entry in pairs(chestLabels) do
            local label = entry.drawing
            local model = entry.model
            if not model or not model.Parent then label.Visible = false continue end
            if not cfg.enabled then label.Visible = false continue end

            local ctype   = entry.ctype
            local enabled = false
            if     ctype == "Common Chest"    and cfg.common    then enabled = true
            elseif ctype == "Uncommon Chest"  and cfg.uncommon  then enabled = true
            elseif ctype == "Rare Chest"      and cfg.rare      then enabled = true
            elseif ctype == "Legendary Chest" and cfg.legendary then enabled = true
            elseif ctype == "Mythical Chest"  and cfg.mythical  then enabled = true
            end

            if not enabled then label.Visible = false continue end

            local dist = hrpPos and getDist(hrpPos, entry.pos) or 0
            if dist > cfg.maxDist then label.Visible = false continue end

            local sp, onScreen = cam:WorldToScreenPoint(Vector3.new(entry.pos.X, entry.pos.Y, entry.pos.Z))
            if not onScreen then label.Visible = false continue end

            label.Text     = ctype .. "  " .. math.floor(dist) .. "m"
            label.Position = Vector2.new(sp.X, sp.Y)
            label.Color    = chestColors[ctype] or Color3.fromRGB(255, 255, 255)
            label.Visible  = true
        end

        -- Vending ESP
        for _, entry in pairs(vendingLabels) do
            local label = entry.drawing
            local model = entry.model
            if not model or not model.Parent then label.Visible = false continue end
            if not cfg.vending then label.Visible = false continue end

            if entry.label == "Vending Machine" then
                local center = model:FindFirstChild("Center")
                if center then
                    for _, c in pairs(center:GetChildren()) do
                        local mapped = VENDING_SOUND_MAP[c.Name]
                        if mapped then entry.label = mapped break end
                    end
                end
            end

            local dist = hrpPos and getDist(hrpPos, entry.pos) or 0
            if dist > cfg.maxDist then label.Visible = false continue end

            local sp, onScreen = cam:WorldToScreenPoint(Vector3.new(entry.pos.X, entry.pos.Y, entry.pos.Z))
            if not onScreen then label.Visible = false continue end

            label.Text     = entry.label .. "  " .. math.floor(dist) .. "m"
            label.Position = Vector2.new(sp.X, sp.Y)
            label.Color    = VENDING_COLOR
            label.Visible  = true
        end
    end
end)
