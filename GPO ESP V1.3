local severeui = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/okdude42/ui-lib/refs/heads/main/SevereLib.lua?t=" .. tostring(tick())
))()

local cfg = {
    enabled   = true,
    mythical  = true,
    legendary = true,
    rare      = true,
    uncommon  = true,
    common    = true,
    vending   = true,
    maxDist   = 15000,
}

local chestColors = {
    ["Common Chest"]    = Color3.fromRGB(210, 160,  80),
    ["Uncommon Chest"]  = Color3.fromRGB(100, 180, 255),
    ["Rare Chest"]      = Color3.fromRGB(255, 215,   0),
    ["Legendary Chest"] = Color3.fromRGB(255, 170,   0),
    ["Mythical Chest"]  = Color3.fromRGB(200, 100, 255),
}
local VENDING_COLOR = Color3.fromRGB(60, 220, 180)

local VENDING_SOUND_MAP = {
    ["Geppo"]           = "Geppo",
    ["VendingMachineE"] = "Fighting Style",
}

local function reload()
